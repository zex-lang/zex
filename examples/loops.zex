# Loops in Zex

# While loop
var i = 0
while i < 5 {
    println("i = " + string(i))
    i += 1
}

# Do-while loop (executes at least once)
var j = 0
do {
    println("j = " + string(j))
    j += 1
} while j < 3

# Break example
var k = 0
while true {
    if k >= 5 {
        break
    }
    println("k = " + string(k))
    k += 1
}

# Continue example
var n = 0
while n < 5 {
    n += 1
    if n == 3 {
        continue
    }
    println("n = " + string(n))
}
