# Zex Programming Language - Test Script

# Variable declarations and assignments
var x = 10
var y = 20
var name = "Zex"

# Arithmetic
var sum = x + y
println("Sum:", sum)

# Compound assignment
x += 5
println("x after += 5:", x)

# Float support
var pi = 3.14159
var radius = 2.5
var area = pi * radius * radius
println("Area:", area)

# Boolean and conditionals
var is_active = true
if is_active {
    println("System is active!")
}

# Comparison operators
if x > 10 {
    println("x is greater than 10")
} else if x == 10 {
    println("x equals 10")
} else {
    println("x is less than 10")
}

# Logical operators
var a = true
var b = false
if a && !b {
    println("a is true AND b is false")
}

if a || b {
    println("At least one is true")
}

# Functions
fun greet(message) {
    println("Greeting:", message)
    return message
}

greet("Hello, World!")

fun add(a, b) {
    return a + b
}

var result = add(15, 27)
println("15 + 27 =", result)

# Type conversion using class constructors
var num = 42
var str_num = string(num)
println("Number as string:", str_num)

var float_val = float(100)
println("Int as float:", float_val)

# String concatenation
var greeting = "Hello, " + name + "!"
println(greeting)

# Class definition
class Person {
    var name = "Unknown"
    var age = 0

    fun init(self, name, age) {
        self.name = name
        self.age = age
    }

    fun greet(self) {
        println("Hello, my name is " + self.name + "!")
    }

    fun get_age(self) {
        return self.age
    }

    fun celebrate_birthday(self) {
        self.age = self.age + 1
        println(self.name + " is now " + string(self.age) + " years old!")
    }
}

# Create instance
var person = Person("Alice", 25)
person.greet()
println("Age:", person.get_age())
person.celebrate_birthday()

# Another instance
var bob = Person("Bob", 30)
bob.greet()

println("=== Zex test completed successfully! ===")
